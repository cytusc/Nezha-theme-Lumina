# 复制本文件为 .deploy.env，然后按你的服务器填写。
# .deploy.env 已加入 .gitignore，不要提交真实配置。

# 服务器 SSH 登录信息
DEPLOY_HOST=example.com
DEPLOY_PORT=22
DEPLOY_USER=root

# 服务器上前端静态文件目录，例如 /opt/lumina/dist 或 /var/www/lumina
DEPLOY_PATH=/opt/lumina/dist

# 可选：指定私钥文件；不填则使用当前系统 ssh-agent / 默认 SSH 配置。
# Windows 示例：C:\Users\Administrator\.ssh\id_ed25519
# Linux/macOS 示例：~/.ssh/id_ed25519
DEPLOY_IDENTITY_FILE=

# 默认部署前会清空 DEPLOY_PATH 下的旧文件，再上传 dist。
DEPLOY_CLEAN=true

# 可选：部署后执行远端命令，例如重载 nginx 或重启服务。
# 必须是免交互命令；如果用 sudo，请配置 NOPASSWD，并建议使用 sudo -n。
# DEPLOY_RESTART_COMMAND=sudo -n systemctl reload nginx
DEPLOY_RESTART_COMMAND=
